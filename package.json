{
  "name": "cast-lumen",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "deploy": "vercel --prod",
    "clean": "rm -rf node_modules/.vite dist",
    "dev:clean": "npm run clean && npm run dev",
    "test:auth": "echo \"✅ Tests d'authentification - Vérifiez: 1) Redirection super-admin 2) Permissions 3) Menu mobile\"",
    "reorganize": "node scripts/complete-reorganization.js",
    "check-structure": "node scripts/check-structure.js",
    "cleanup": "node scripts/cleanup-old-files.js",
    "restructure": "npm run reorganize && npm run check-structure",
    "fix-imports": "node scripts/fix-dashboard-imports.js",
    "final-check": "npm run reorganize && npm run check-structure && npm run fix-imports",
    "migrate-all": "npm run reorganize && echo \"🎉 Migration terminée! Vérifiez votre structure.\"",
    "diagnose": "node scripts/diagnose-missing-files.js",
    "fix-imports-all": "node scripts/fix-all-imports.js",
    "fix-all": "node scripts/fix-all-imports-complete.js",
    "final-fix": "node scripts/final-import-fix.js",
    "repair": "node scripts/repair-corrupted-files.js",
    "final-repair": "node scripts/final-repair-all.js",
    "fix-cycles": "node scripts/fix-import-cycles.js"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "chalk": "^5.6.2",
    "firebase": "^12.4.0",
    "firebase-admin": "^13.5.0",
    "lucide-react": "^0.546.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "vite": "^5.4.0"
  }
}
